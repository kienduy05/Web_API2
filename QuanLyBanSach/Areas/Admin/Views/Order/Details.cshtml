@model QuanLyBanSach.Models.Order
@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers
@{
    Layout = "~/Areas/Admin/Views/Shared/_LayoutAdmin.cshtml";
    var orderDetails = ViewBag.OrderDetails as List<QuanLyBanSach.Models.OrderDetail>;
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h3 class="fw-bold">📦 Đơn hàng #@Model.OrderID</h3>
    <a asp-action="Index" class="btn btn-secondary">
        <i data-feather="arrow-left"></i> Quay lại
    </a>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success">@TempData["Success"]</div>
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger">@TempData["Error"]</div>
}

<div class="row">
    <div class="col-md-8">
        <!-- THÔNG TIN ĐƠN HÀNG -->
        <div class="card mb-3">
            <div class="card-header bg-primary text-white">
                <h5 class="card-title mb-0">Thông tin nhận hàng</h5>
            </div>
            <div class="card-body">
                <div class="row mb-2">
                    <div class="col-md-6">
                        <p><strong>Mã đơn hàng:</strong> #@Model.OrderID</p>
                        <p><strong>Mã khách hàng:</strong> @Model.CustomerID</p>
                    </div>
                    <div class="col-md-6">
                        <p><strong>Tên khách hàng:</strong> @Model.CustomerName</p>
                    </div>
                </div>
                <div class="row mb-2">
                    <div class="col-md-6">
                        <p><strong>Người nhận:</strong> @Model.ReceiverName</p>
                        <p><strong>SĐT:</strong> @Model.ReceiverPhone</p>
                        <p><strong>Địa chỉ:</strong> @Model.ReceiverAddress</p>
                    </div>
                    <div class="col-md-6">
                        <p><strong>Ngày tạo:</strong> @Model.OrderCreatedDate.ToString("dd/MM/yyyy HH:mm:ss")</p>
                        <p><strong>Trạng thái:</strong>
                            @{
                                var statusBadge = Model.OrderStatus switch
                                {
                                    0 => "warning",
                                    1 => "info",
                                    2 => "success",
                                    _ => "secondary"
                                };
                                var statusText = Model.OrderStatus switch
                                {
                                    0 => "Đang chuẩn bị",
                                    1 => "Đang giao",
                                    2 => "Đã giao",
                                    _ => "Không xác định"
                                };
                            }
                            <span class="badge bg-@statusBadge">@statusText</span>
                        </p>
                    </div>
                </div>
            </div>
        </div>

        <!-- CHI TIẾT SẢN PHẨM -->
        <div class="card mb-3">
            <div class="card-header bg-light">
                <h5 class="card-title mb-0">Chi tiết sản phẩm</h5>
            </div>
            <div class="card-body">
                @if (orderDetails != null && orderDetails.Count > 0)
                {
                    <table class="table table-bordered">
                        <thead class="table-dark">
                            <tr>
                                <th>Sách</th>
                                <th>SL</th>
                                <th>Giá</th>
                                <th>Vận chuyển</th>
                                <th>Thành tiền</th>
                            </tr>
                        </thead>
                        <tbody>
                            @{
                                decimal subtotal = 0;
                                decimal shipping = 50000;
                                int itemCount = orderDetails.Count;
                                int index = 0;
                            }
                            @foreach (var detail in orderDetails)
                            {
                                index++;
                                decimal totalPrice = detail.Quantity * detail.UnitPrice;
                                subtotal += totalPrice;
                                var totalWithShipping = totalPrice + (index == 1 ? shipping : 0);

                                <tr>
                                    <td>@detail.BookName</td>
                                    <td>@detail.Quantity</td>
                                    <td>@detail.UnitPrice.ToString("N0") đ</td>
                                    <td>@(index == 1 ? shipping.ToString("N0") + " đ" : "-")</td>
                                    <td>@totalWithShipping.ToString("N0") đ</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
                else
                {
                    <div class="alert alert-info">Không có sản phẩm trong đơn hàng này.</div>
                }
            </div>
        </div>
    </div>

    <div class="col-md-4">
        <div class="card">
            <div class="card-header bg-light">
                <h5 class="card-title mb-0">Cập nhật trạng thái</h5>
            </div>
            <div class="card-body">
                <div class="mb-3">
                    <p><strong>Trạng thái hiện tại:</strong></p>
                    @{
                        var currentStatusBadge = Model.OrderStatus switch
                        {
                            0 => "warning",
                            1 => "info",
                            2 => "success",
                            _ => "secondary"
                        };
                        var currentStatusText = Model.OrderStatus switch
                        {
                            0 => "Đang chuẩn bị",
                            1 => "Đang giao",
                            2 => "Đã giao",
                            _ => "Không xác định"
                        };
                    }
                    <span class="badge bg-@currentStatusBadge">@currentStatusText</span>
                </div>

                <a asp-action="EditStatus" 
                   asp-route-id="@Model.OrderID"
                   class="btn btn-primary btn-sm w-100">
                    <i data-feather="edit-2"></i> Cập nhật trạng thái
                </a>
            </div>
        </div>
    </div>
</div>
