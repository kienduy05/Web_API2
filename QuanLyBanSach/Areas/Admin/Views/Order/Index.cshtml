@model List<QuanLyBanSach.Models.Order>
@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers
@{
    Layout = "~/Areas/Admin/Views/Shared/_LayoutAdmin.cshtml";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h3 class="fw-bold">Quản lý đơn hàng</h3>
</div>

<form method="get" class="row mb-3" id="searchForm">
    <div class="col-md-3">
        <input type="text" name="keyword" class="form-control"
               placeholder="Nhập từ khóa..."
               value="@ViewBag.Keyword" />
    </div>

    <div class="col-md-3">
        <select name="type" class="form-control" id="searchType" required>
            <option value="">-- Chọn kiểu tìm --</option>
            @if (ViewBag.Type == "id")
            {
                <option value="id" selected>Mã đơn</option>
            }
            else
            {
                <option value="id">Mã đơn</option>
            }
            @if (ViewBag.Type == "customer")
            {
                <option value="customer" selected>Tên khách hàng</option>
            }
            else
            {
                <option value="customer">Tên khách hàng</option>
            }
            @if (ViewBag.Type == "phone")
            {
                <option value="phone" selected>SĐT</option>
            }
            else
            {
                <option value="phone">SĐT</option>
            }
        </select>
    </div>

    <div class="col-md-2">
        <button type="submit" class="btn btn-primary" onclick="return validateSearch()">
            <i data-feather="search"></i> Tìm
        </button>
    </div>

    <div class="col-md-2">
        <a asp-action="Index" class="btn btn-secondary">
            <i data-feather="x"></i> Reset
        </a>
    </div>
</form>

<!-- Form tìm kiếm theo tháng/năm -->
<form method="get" class="row mb-3" id="monthYearForm">
    <div class="col-md-2">
        <input type="number" 
               name="month" 
               class="form-control" 
               placeholder="Tháng (1-12)"
               min="1"
               max="12"
               value="@ViewBag.Month"
               id="monthInput" />
    </div>

    <div class="col-md-2">
        <input type="number" 
               name="year" 
               class="form-control" 
               placeholder="Năm (VD: 2024)"
               min="2000"
               max="9999"
               value="@ViewBag.Year"
               id="yearInput" />
    </div>

    <div class="col-md-2">
        <button type="submit" class="btn btn-info" onclick="return validateMonthYear()">
            <i data-feather="calendar"></i> Tìm theo tháng/năm
        </button>
    </div>
</form>

<script>
    function validateMonthYear() {
        var month = document.getElementById('monthInput').value.trim();
        var year = document.getElementById('yearInput').value.trim();

        var currentDate = new Date();
        var currentMonth = currentDate.getMonth() + 1;
        var currentYear = currentDate.getFullYear();

        // Nếu cả tháng và năm đều để trống, cho phép submit (không filter)
        if (!month && !year) {
            return true;
        }

        // Nếu chỉ nhập một trong hai, yêu cầu nhập cả hai
        if ((month && !year) || (!month && year)) {
            alert('Vui lòng nhập cả tháng và năm!');
            return false;
        }

        // Validate tháng
        month = parseInt(month);
        if (isNaN(month) || month < 1 || month > 12) {
            alert('Tháng phải từ 1 đến 12!');
            return false;
        }

        // Validate năm
        year = parseInt(year);
        if (isNaN(year) || year < 2000 || year > currentYear) {
            alert('Năm phải từ 2000 đến ' + currentYear + '!');
            return false;
        }

        // Check nếu năm bằng năm hiện tại, tháng không được vượt quá tháng hiện tại
        if (year === currentYear && month > currentMonth) {
            alert('Tháng không được vượt quá tháng hiện tại (' + currentMonth + ')!');
            return false;
        }

        return true;
    }
</script>

<script>
    function validateSearch() {
        var keyword = document.querySelector('input[name="keyword"]').value.trim();
        var type = document.getElementById('searchType').value;

        if (!keyword) {
            alert('Vui lòng nhập từ khóa tìm kiếm!');
            return false;
        }

        if (!type) {
            alert('Vui lòng chọn kiểu tìm!');
            return false;
        }

        return true;
    }
</script>

<div class="row mb-3">
    <div class="col-md-12">
        <div class="btn-group" role="group">
            <a asp-action="Index" 
               class="btn @(ViewBag.Status == null ? "btn-primary" : "btn-outline-primary")">
                <i data-feather="list"></i> Tất cả
            </a>
            <a asp-action="Index" asp-route-status="0"
               class="btn @(ViewBag.Status == 0 ? "btn-warning" : "btn-outline-warning")">
                <i data-feather="clock"></i> Đang chuẩn bị
            </a>
            <a asp-action="Index" asp-route-status="1"
               class="btn @(ViewBag.Status == 1 ? "btn-info" : "btn-outline-info")">
                <i data-feather="truck"></i> Đang giao
            </a>
            <a asp-action="Index" asp-route-status="2"
               class="btn @(ViewBag.Status == 2 ? "btn-success" : "btn-outline-success")">
                <i data-feather="check-circle"></i> Đã giao
            </a>
        </div>
    </div>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success">@TempData["Success"]</div>
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger">@TempData["Error"]</div>
}

<div class="card">
    <div class="card-body">
        @if (Model.Count > 0)
        {
            <table class="table table-hover align-middle">
                <thead class="table-light">
                    <tr>
                        <th>Mã đơn</th>
                        <th>Mã khách</th>
                        <th>Tên khách</th>
                        <th>Ngày tạo</th>
                        <th>SĐT nhận</th>
                        <th>Tổng tiền</th>
                        <th>Trạng thái</th>
                        <th class="text-center">Hành động</th>
                    </tr>
                </thead>

                <tbody>
                    @foreach (var item in Model)
                    {
                        var statusBadge = item.OrderStatus switch
                        {
                            0 => "warning",
                            1 => "info",
                            2 => "success",
                            _ => "secondary"
                        };

                        var statusText = item.OrderStatus switch
                        {
                            0 => "Đang chuẩn bị",
                            1 => "Đang giao",
                            2 => "Đã giao",
                            _ => "Không xác định"
                        };

                        <tr>
                            <td><strong>#@item.OrderID</strong></td>
                            <td>@item.CustomerID</td>
                            <td>@item.CustomerName</td>
                            <td>@item.OrderCreatedDate.ToString("dd/MM/yyyy HH:mm")</td>
                            <td>@item.ReceiverPhone</td>
                            <td>@item.OrderTotalAmount.ToString("N0") đ</td>
                            <td>
                                <span class="badge bg-@statusBadge">@statusText</span>
                            </td>
                            <td class="text-center">
                                <a asp-area="Admin"
                                   asp-controller="Order"
                                   asp-action="Details"
                                   asp-route-id="@item.OrderID"
                                   class="btn btn-info btn-sm"
                                   title="Xem chi tiết">
                                    <i data-feather="eye"></i>
                                </a>

                                <a asp-area="Admin"
                                   asp-controller="Order"
                                   asp-action="EditStatus"
                                   asp-route-id="@item.OrderID"
                                   class="btn btn-warning btn-sm"
                                   title="Cập nhật trạng thái">
                                    <i data-feather="edit"></i>
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>

            <!-- Pagination -->
            <nav aria-label="Page navigation">
                <ul class="pagination justify-content-center">
                    @if (ViewBag.CurrentPage > 1)
                    {
                        <li class="page-item">
                            <a class="page-link" asp-action="Index" 
                               asp-route-page="@(ViewBag.CurrentPage - 1)"
                               asp-route-keyword="@ViewBag.Keyword"
                               asp-route-type="@ViewBag.Type"
                               asp-route-status="@ViewBag.Status"
                               asp-route-month="@ViewBag.Month"
                               asp-route-year="@ViewBag.Year">Previous</a>
                        </li>
                    }
                    else
                    {
                        <li class="page-item disabled">
                            <span class="page-link">Previous</span>
                        </li>
                    }

                    @{
                        int totalPages = ViewBag.TotalPages;
                        int currentPage = ViewBag.CurrentPage;
                        int startPage = Math.Max(1, currentPage - 2);
                        int endPage = Math.Min(totalPages, currentPage + 2);

                        // Nếu còn trang trước startPage, hiển thị trang 1 và "..."
                        if (startPage > 1)
                        {
                            <li class="page-item">
                                <a class="page-link" asp-action="Index" 
                                   asp-route-page="1"
                                   asp-route-keyword="@ViewBag.Keyword"
                                   asp-route-type="@ViewBag.Type"
                                   asp-route-status="@ViewBag.Status"
                                   asp-route-month="@ViewBag.Month"
                                   asp-route-year="@ViewBag.Year">1</a>
                            </li>
                            if (startPage > 2)
                            {
                                <li class="page-item disabled">
                                    <span class="page-link">...</span>
                                </li>
                            }
                        }

                        // Hiển thị số trang từ startPage đến endPage
                        for (int i = startPage; i <= endPage; i++)
                        {
                            if (i == currentPage)
                            {
                                <li class="page-item active">
                                    <span class="page-link">@i</span>
                                </li>
                            }
                            else
                            {
                                <li class="page-item">
                                    <a class="page-link" asp-action="Index" 
                                       asp-route-page="@i"
                                       asp-route-keyword="@ViewBag.Keyword"
                                       asp-route-type="@ViewBag.Type"
                                       asp-route-status="@ViewBag.Status"
                                       asp-route-month="@ViewBag.Month"
                                       asp-route-year="@ViewBag.Year">@i</a>
                                </li>
                            }
                        }

                        // Nếu còn trang sau endPage, hiển thị "..." và trang cuối
                        if (endPage < totalPages)
                        {
                            if (endPage < totalPages - 1)
                            {
                                <li class="page-item disabled">
                                    <span class="page-link">...</span>
                                </li>
                            }
                            <li class="page-item">
                                <a class="page-link" asp-action="Index" 
                                   asp-route-page="@totalPages"
                                   asp-route-keyword="@ViewBag.Keyword"
                                   asp-route-type="@ViewBag.Type"
                                   asp-route-status="@ViewBag.Status"
                                   asp-route-month="@ViewBag.Month"
                                   asp-route-year="@ViewBag.Year">@totalPages</a>
                            </li>
                        }
                    }

                    @if (ViewBag.CurrentPage < ViewBag.TotalPages)
                    {
                        <li class="page-item">
                            <a class="page-link" asp-action="Index" 
                               asp-route-page="@(ViewBag.CurrentPage + 1)"
                               asp-route-keyword="@ViewBag.Keyword"
                               asp-route-type="@ViewBag.Type"
                               asp-route-status="@ViewBag.Status"
                               asp-route-month="@ViewBag.Month"
                               asp-route-year="@ViewBag.Year">Next</a>
                        </li>
                    }
                    else
                    {
                        <li class="page-item disabled">
                            <span class="page-link">Next</span>
                        </li>
                    }
                </ul>
            </nav>
        }
        else
        {
            <div class="alert alert-info">
                Không có đơn hàng nào.
            </div>
        }
    </div>
</div>
