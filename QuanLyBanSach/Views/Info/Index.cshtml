@{
    Layout = "~/Views/Shared/_LayoutBook.cshtml";
}

<!-- About Us Section (Full Height Style) -->
<section class="about-section py-5" style="min-height: 90vh; background-color: #fff;">
    <div class="container">
        <div class="row align-items-center">
            <!-- Left: Image -->
            <div class="col-lg-6 mb-4 mb-lg-0">
                <div class="about-image-wrapper position-relative">
                    <img src="https://images.unsplash.com/photo-1524995997946-a1c2e315a42f?w=1000"
                         alt="About Us" class="img-fluid rounded-4 shadow-lg w-100">
                    <div class="about-overlay position-absolute top-0 start-0 w-100 h-100 rounded-4"
                         style="background: rgba(0,0,0,0.2);"></div>
                </div>
            </div>

            <!-- Right: Content -->
            <div class="col-lg-6 ps-lg-5">
                <h2 class="fw-bold mb-3" style="color: #ED553B;">Về Chúng Tôi</h2>
                <p class="text-muted fs-6 mb-4">
                    Tại <strong>BookStoreVA1</strong>, chúng tôi tin rằng mỗi cuốn sách không chỉ là những con chữ, mà còn là cánh cửa mở ra những chân trời tri thức, cảm hứng và trải nghiệm mới.
                    Với mong muốn kết nối người đọc với những cuốn sách phù hợp nhất, chúng tôi xây dựng một không gian mua sắm trực tuyến tiện lợi, thân thiện và đầy cảm hứng.
                </p>
                <p class="text-muted fs-6 mb-4">
                    Từ những tác phẩm văn học hiện đại, kinh điển vượt thời gian đến sách kỹ năng, học thuật — kho sách được tuyển chọn kỹ lưỡng của chúng tôi luôn sẵn sàng đáp ứng mọi nhu cầu đọc.
                    BookStoreVA1 không chỉ là nơi mua sách, mà còn là nơi nuôi dưỡng niềm đam mê đọc và lan tỏa giá trị tri thức trong cộng đồng.
                </p>
                <div class="d-flex flex-wrap gap-3 mt-4">
                    <a asp-controller="Book" asp-action="Index" class="btn text-white px-4 py-2 fw-semibold" style="background-color: #ED553B;">Khám phá sách</a>
                    <a asp-controller="Contact" asp-action="Index" class="btn btn-outline-secondary px-4 py-2 fw-semibold">Liên hệ</a>
                </div>
            </div>
        </div>
    </div>
</section>
