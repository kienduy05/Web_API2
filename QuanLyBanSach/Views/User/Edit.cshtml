@model QuanLyBanSach.Models.Customer
@{
    Layout = "~/Views/Shared/_LayoutBook.cshtml";
}

<div class="container mt-4">
    <h3>✏️ Cập nhật thông tin cá nhân</h3>

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger">@TempData["Error"]</div>
    }

    <form asp-action="Edit" method="post">
        <div class="mb-3">
            <label>Họ tên</label>
            <input asp-for="CustomerName" class="form-control" />
        </div>

        <div class="mb-3">
            <label>Số điện thoại</label>
            <input asp-for="CustomerPhone" class="form-control" />
        </div>

        <div class="mb-3">
            <label>Email</label>
            <input asp-for="CustomerEmail" class="form-control" />
        </div>

        <div class="mb-3">
            <label>Địa chỉ</label>
            <input asp-for="CustomerAddress" class="form-control" />
        </div>

        <button type="submit" class="btn btn-success">💾 Lưu</button>
        <a asp-action="Index" class="btn btn-secondary">Quay lại</a>
    </form>
</div>