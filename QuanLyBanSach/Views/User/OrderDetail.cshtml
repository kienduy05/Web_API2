@model QuanLyBanSach.Models.ViewModels.OrderDetailFullVM
@{
    Layout = "~/Views/Shared/_LayoutBook.cshtml";
}

<div class="container mt-4">

    <h3>📦 Đơn hàng #@Model.Order.OrderID</h3>

    <!-- INFO -->
    <div class="card mb-3">
        <div class="card-header bg-primary text-white">
            Thông tin nhận hàng
        </div>
        <div class="card-body">
            <div class="row mb-2">
                <div class="col-md-6">
                    <p><b>Mã đơn hàng:</b> #@Model.Order.OrderID</p>
                    <p><b>Mã khách hàng:</b> @Model.Order.CustomerID</p>
                    <p><b>Người nhận:</b> @Model.Order.ReceiverName</p>
                    <p><b>SĐT:</b> @Model.Order.ReceiverPhone</p>
                    <p><b>Địa chỉ:</b> @Model.Order.ReceiverAddress</p>
                </div>
                <div class="col-md-6">
                    <p><b>Tên khách hàng:</b> @Model.Order.CustomerName</p>
                    <p><b>Ngày:</b> @Model.Order.OrderCreatedDate.ToString("dd/MM/yyyy HH:mm:ss")</p>
                    <p>
                        <b>Trạng thái:</b>
                        @switch (Model.Order.OrderStatus)
                        {
                            case 0:
                                <span class="badge bg-warning">Đang chuẩn bị</span>
                                break;
                            case 1:
                                <span class="badge bg-info">Đang giao</span>
                                break;
                            case 2:
                                <span class="badge bg-success">Đã giao</span>
                                break;
                        }
                    </p>
                </div>
            </div>
        </div>
    </div>

    <!-- PRODUCTS -->
    <table class="table table-bordered">
        <thead class="table-dark">
            <tr>
                <th>Sách</th>
                <th>SL</th>
                <th>Giá</th>
                <th>Vận chuyển</th>
                <th>Thành tiền</th>
            </tr>
        </thead>

        <tbody>
            @{
                decimal subtotal = 0;
                decimal shipping = 50000; // Tiền vận chuyển
                int itemCount = Model.Details.Count;
                int index = 0;
            }

            @foreach (var item in Model.Details)
            {
                index++;
                var sub = item.Quantity * item.UnitPrice;
                subtotal += sub;
                var totalWithShipping = sub + (index == 1 ? shipping : 0); // Cộng vận chuyển vào sản phẩm đầu tiên

                <tr>
                    <td>@item.BookName</td>
                    <td>@item.Quantity</td>
                    <td>@item.UnitPrice.ToString("N0") đ</td>
                    <td>@(index == 1 ? shipping.ToString("N0") + " đ" : "-")</td>
                    <td>@totalWithShipping.ToString("N0") đ</td>
                </tr>
            }
        </tbody>
    </table>

    <a asp-action="Index" class="btn btn-secondary mt-3">⬅ Quay lại</a>

</div>