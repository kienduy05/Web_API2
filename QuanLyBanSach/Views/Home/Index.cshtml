@{
    ViewData["Title"] = "Home Page";
    Layout = "~/Views/Shared/_LayoutBook.cshtml";
}

<!-- Section 3: Single Image Carousel -->
<div id="bookCarousel" class="carousel slide" data-bs-ride="carousel">

    <!-- Indicators -->
    <div class="carousel-indicators">
        <button type="button" data-bs-target="#bookCarousel" data-bs-slide-to="0" class="active"
                aria-current="true"></button>
        <button type="button" data-bs-target="#bookCarousel" data-bs-slide-to="1"></button>
        <button type="button" data-bs-target="#bookCarousel" data-bs-slide-to="2"></button>
    </div>

    <!-- Carousel Slides -->
    <div class="carousel-inner">
        <div class="carousel-item active">
            <img src="~/LayoutBook/images/banner1.png" class="d-block w-100" alt="Book Banner 1">
            </div>
            <div class="carousel-item">
                <img src="~/LayoutBook/images/banner1.png" class="d-block w-100" alt="Book Banner 2">
                </div>
                <div class="carousel-item">
                    <img src="~/LayoutBook/images/banner1.png" class="d-block w-100" alt="Book Banner 3">
                    </div>
                </div>

                <!-- Controls -->
                <button class="carousel-control-prev" type="button" data-bs-target="#bookCarousel" data-bs-slide="prev">
                    <span class="carousel-control-prev-icon"></span>
                </button>
                <button class="carousel-control-next" type="button" data-bs-target="#bookCarousel" data-bs-slide="next">
                    <span class="carousel-control-next-icon"></span>
                </button>
            </div>




            <!-- Top Categories Section -->
            <section class="categories-section py-5">
                <partial name="_PartialCategoriesSection" />
            </section>


            <!-- eBook Section -->
            <section class="ebook-section py-5">
                <partial name="_PartialEbookSection" />
            </section>



@* //Body to code here *@
<h1>Main Content</h1>
@* //End *@




            @* Featured Section *@
            <partial name="_PartialFeaturedSection" />
            @* End featured section *@




            <!-- Offer Section -->
            <section class="offer-section container">
                <div class="row align-items-center">
                    <div class="col-md-6 offer-text">
                        <h2>🔥 Giảm giá đến 50% toàn bộ sách – Cơ hội không thể bỏ lỡ!</h2>
                        <p>
                            Nhanh tay sở hữu những đầu sách bạn yêu thích với mức giá ưu đãi chưa từng có.
                            Số lượng có hạn – mua ngay hôm nay để không bỏ lỡ cơ hội nâng cấp tri thức với chi phí tiết kiệm nhất!
                        </p>
                        <div class="timer">
                            <div>768 <span>Ngày</span></div>
                            <div>01 <span>Giờ</span></div>
                            <div>27 <span>Phút</span></div>
                            <div>55 <span>Giây</span></div>
                        </div>
                    </div>
                    <div class="col-md-6 text-center">
                        <img src="~/LayoutBook/images/Unsplash.png" alt="Books" class="offer-img img-fluid">
                        </div>
                    </div>
                </section>
                <!-- Newsletter Section -->
                <section class="newsletter-section">
                    <h3>Đăng ký nhận thông tin mới nhất</h3>
                    <p>
                        Nhận ngay những ưu đãi độc quyền, sách mới phát hành và nội dung hữu ích
                        được gửi trực tiếp đến email của bạn mỗi tuần.
                    </p>
                    <div class="newsletter-input">
                        <input type="email" placeholder="Nhập địa chỉ email của bạn">
                        <button>Đăng ký</button>
                    </div>
                </section>




