@model QuanLyBanSach.Models.ViewModels.AuthViewModel
@{
    ViewData["Title"] = "Login";
    Layout = null;
}

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">

<section class="auth-section">
    <div class="container-fluid">
        <div class="row g-0">

            <!-- Left Image -->
            <div class="col-lg-6 d-none d-lg-block position-relative auth-image">
                <img src="https://images.unsplash.com/photo-1512820790803-83ca734da794?w=1000"
                     class="img-fluid vh-100"
                     style="object-fit: cover;">
         
                <div class="overlay-text position-absolute top-50 start-50 translate-middle text-center text-white px-3">
                    <h2 class="fw-bold">Chào mừng đến với <span style="color:#ED553B;">BookStoreVA1</span></h2>
                    <p>Khám phá, đọc và phát triển cùng bộ sưu tập sách được chọn lọc của chúng tôi</p>
                </div>
            </div>

            <!-- Right Form -->
            <div class="col-lg-6 d-flex align-items-center justify-content-center">
                <div class="auth-form-wrapper w-100 p-5">

                    <!-- Tabs -->
                    <ul class="nav nav-tabs justify-content-center mb-4 border-0">
                        <li class="nav-item">
                            <button class="nav-link active fw-semibold" data-bs-toggle="tab"
                                    data-bs-target="#loginTab">
                                Đăng nhập
                            </button>
                        </li>

                        <li class="nav-item">
                            <button class="nav-link fw-semibold" data-bs-toggle="tab"
                                    data-bs-target="#registerTab">
                                Đăng kí
                            </button>
                        </li>
                    </ul>

                    <div class="tab-content">

                        <!-- LOGIN -->
                        <div class="tab-pane fade show active" id="loginTab">

                            <h4 class="fw-bold mb-4 text-center text-danger">Đăng nhập vào tài khoản của bạn</h4>

                            @if (TempData["Success"] != null)
                            {
                                <div class="alert alert-success">@TempData["Success"]</div>
                            }

                            @if (TempData["Error"] != null)
                            {
                                <div class="alert alert-danger">@TempData["Error"]</div>
                            }

                            <form asp-controller="Access" asp-action="Login" method="post">

                                <div class="mb-3">
                                    <label class="form-label">Tên đăng nhập</label>
                                    <input asp-for="Login.Username" class="form-control form-control-lg" />
                                </div>

                                <div class="mb-3">
                                    <label class="form-label">Mật khẩu</label>
                                    <input asp-for="Login.Password" type="password"
                                           class="form-control form-control-lg" />
                                </div>

                                <button class="btn w-100 py-2 text-white fw-semibold"
                                        style="background-color:#ED553B;">
                                    Đăng nhập
                                </button>

                            </form>

                        </div>

                        <!-- REGISTER  -->
                        <div class="tab-pane fade" id="registerTab">

                            <h4 class="fw-bold mb-4 text-center text-danger">
                                Tạo tài khoản của bạn
                            </h4>

                            @if (TempData["Success"] != null)
                            {
                                <div class="alert alert-success">@TempData["Success"]</div>
                            }

                            @if (TempData["Error"] != null)
                            {
                                <div class="alert alert-danger">@TempData["Error"]</div>
                            }

                            <form asp-controller="Access" asp-action="Register" method="post">

                                <div asp-validation-summary="All" class="text-danger mb-3"></div>

                                <div class="row">

                                    <div class="col-md-6 mb-3">
                                        <label>Họ và tên</label>
                                        <input asp-for="Register.CustomerName" class="form-control form-control-lg" />
                                        <span asp-validation-for="Register.CustomerName" class="text-danger"></span>
                                    </div>

                                    <div class="col-md-6 mb-3">
                                        <label>Số điện thoại</label>
                                        <input asp-for="Register.CustomerPhone" class="form-control form-control-lg" />
                                        <span asp-validation-for="Register.CustomerPhone" class="text-danger"></span>
                                    </div>

                                </div>

                                <div class="mb-3">
                                    <label>Email</label>
                                    <input asp-for="Register.CustomerEmail" class="form-control form-control-lg" />
                                    <span asp-validation-for="Register.CustomerEmail" class="text-danger"></span>
                                </div>

                                <div class="mb-3">
                                    <label>Địa chỉ</label>
                                    <input asp-for="Register.CustomerAddress" class="form-control form-control-lg" />
                                    <span asp-validation-for="Register.CustomerAddress" class="text-danger"></span>
                                </div>

                                <div class="mb-3">
                                    <label>Tên đăng nhập</label>
                                    <input asp-for="Register.Username" class="form-control form-control-lg" />
                                    <span asp-validation-for="Register.Username" class="text-danger"></span>
                                </div>

                                <div class="mb-3">
                                    <label>Mật khẩu</label>
                                    <input asp-for="Register.Password" type="password" class="form-control form-control-lg" />
                                    <span asp-validation-for="Register.Password" class="text-danger"></span>
                                </div>

                                <div class="mb-3">
                                    <label>Xác nhận mật khẩu</label>
                                    <input asp-for="Register.ConfirmPassword" type="password" class="form-control form-control-lg" />
                                    <span asp-validation-for="Register.ConfirmPassword" class="text-danger"></span>
                                </div>

                                <button class="btn w-100 py-2 text-white fw-semibold"
                                        style="background-color:#ED553B;">
                                    Đăng ký
                                </button>

                            </form>

                        </div>

                    </div>

                </div>
            </div>

        </div>
    </div>
</section>

<style>

    .auth-section .nav-tabs .nav-link {
        border-radius: 50px;
        color: #333;
        transition: 0.3s;
    }

        .auth-section .nav-tabs .nav-link.active {
            background-color: #ED553B;
            color: white;
        }

    .auth-section input:focus {
        border-color: #ED553B !important;
        box-shadow: 0 0 0 0.2rem rgba(237, 85, 59, 0.25);
    }

</style>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>