
@model List<QuanLyBanSach.Controllers.CartItemDetail>
@{
    Layout = "~/Views/Shared/_LayoutBook.cshtml";
}

<!-- 🛒 CART SECTION -->
<section class="container py-5">
    <h4 class="section-title">Giỏ hàng của tôi</h4>
    <div class="row g-4">
        <div class="col-lg-8">
            <!-- Thông báo giỏ hàng trống -->
            <div class="empty-cart-message" id="emptyCartMessage" style="display: @(Model.Count == 0 ? "block" : "none")">
                <div class="card border-0 shadow-sm p-5 text-center">
                    <i class="bi bi-cart-x" style="font-size: 3rem; color: #dc3545;"></i>
                    <h5 class="mt-3 fw-bold">Giỏ hàng của bạn trống</h5>
                    <p class="text-muted">Hãy tiếp tục mua sắm để thêm sản phẩm vào giỏ hàng.</p>
                    <a href="@Url.Action("Index", "Book")" class="btn btn-theme mt-3">Tiếp tục mua sắm</a>
                </div>
            </div>

            <!-- Sản phẩm giỏ hàng -->
            <div class="cart-items-container" id="cartItemsContainer">
                @foreach (var item in Model)
                {
                    <div class="card border-0 shadow-sm mb-3 p-3 d-flex flex-row align-items-center cart-item" data-book-id="@item.BookId">
                        @if (!string.IsNullOrEmpty(item.BookImage))
                        {
                            <img src="@Url.Content($"~/images/books/{item.BookImage}")" class="rounded me-3"
                                 width="80" alt="">
                        }
                        else
                        {
                            <div class="rounded me-3 bg-light d-flex align-items-center justify-content-center"
                                 style="width: 80px; height: 80px;">
                                <i class="bi bi-image text-muted"></i>
                            </div>
                        }
                        <div class="flex-grow-1">
                            <h6 class="fw-bold mb-1">@item.BookName</h6>
                            <p class="text-muted small mb-1">@item.PublisherName</p>
                            <p class="fw-semibold text-danger mb-0">@item.BookPrice.ToString("N0") ₫</p>
                        </div>
                        <div>
                            <input type="number" class="form-control form-control-sm mb-2 quantity" value="@item.Quantity" min="1"
                                   style="width: 70px;">
                            <button type="button" class="btn btn-sm btn-outline-danger delete-btn">Xóa</button>
                        </div>
                    </div>
                }
            </div>
        </div>

        <div class="col-lg-4">
            <div class="card border-0 shadow-sm p-3">
                <h6 class="fw-bold mb-3">Tóm tắt đơn hàng</h6>
                <div class="d-flex justify-content-between mb-2">
                    <span>Tạm tính</span><span id="subtotal">₹0</span>
                </div>
                <div class="d-flex justify-content-between mb-2">
                    <span>Vận chuyển</span><span id="shipping">50,000 ₫</span>
                </div>
                <hr>
                <div class="d-flex justify-content-between fw-bold mb-3">
                    <span>Tổng</span><span id="total">₹50</span>
                </div>
                <button class="btn btn-theme w-100" id="checkoutBtn" 
                        onclick="location.href='@Url.Action("Index", "Checkout")'">
                    <i class="bi bi-credit-card me-2"></i>
                    Tiến hành thanh toán
                </button>
            </div>
        </div>
    </div>
</section>

@section Scripts {
    <script>
        // Hàm xử lý thanh toán
        function proceedToCheckout() {
            const cartItems = document.querySelectorAll('.cart-item');

            if (cartItems.length === 0) {
                alert('⚠️ Không có đơn để thanh toán\n\nVui lòng thêm sản phẩm vào giỏ hàng trước khi thanh toán.');
                return false;
            }

            // Nếu có sản phẩm, chuyển hướng tới trang checkout
            window.location.href = '@Url.Action("Index", "Checkout")';
        }

        // Hàm kiểm tra và cập nhật trạng thái giỏ hàng
        function updateCartState() {
            const cartItems = document.querySelectorAll('.cart-item');
            const emptyMessage = document.getElementById('emptyCartMessage');
            const checkoutBtn = document.getElementById('checkoutBtn');

            if (cartItems.length === 0) {
                emptyMessage.style.display = 'block';
                checkoutBtn.disabled = true;
            } else {
                emptyMessage.style.display = 'none';
                checkoutBtn.disabled = false;
            }
        }

        // Hàm tính toán lại tóm tắt đơn hàng
        function updateOrderSummary() {
            let subtotal = 0;
            const cartItems = document.querySelectorAll('.cart-item');

            cartItems.forEach(item => {
                const priceText = item.querySelector('.fw-semibold.text-danger').textContent;
                // Parse: "90,000 ₫" -> remove spaces and ₫ -> "90,000" -> remove comma -> 90000
                const price = parseFloat(priceText.replace(/\s/g, '').replace('₫', '').replace(/,/g, ''));
                const quantity = parseInt(item.querySelector('.quantity').value);
                subtotal += price * quantity;
            });

            const shipping = 50000; // Vận chuyển: 50,000 đồng
            const total = subtotal + shipping;

            // Cập nhật HTML với định dạng "90,000 ₫"
            document.getElementById('subtotal').textContent = subtotal.toLocaleString('vi-VN') + ' ₫';
            document.getElementById('total').textContent = total.toLocaleString('vi-VN') + ' ₫';
        }

        document.addEventListener('DOMContentLoaded', function() {
            // Kiểm tra trạng thái ban đầu
            updateCartState();
            updateOrderSummary();

            // Xử lý nút xóa
            const deleteButtons = document.querySelectorAll('.delete-btn');
            deleteButtons.forEach(button => {
                button.addEventListener('click', function(e) {
                    e.preventDefault();
                    const cartItem = this.closest('.cart-item');
                    const bookId = cartItem.getAttribute('data-book-id');

                    // Hiển thị xác nhận
                    if (confirm('Bạn có chắc chắn muốn xóa sản phẩm này khỏi giỏ hàng?')) {
                        // Loại bỏ mục khỏi DOM với hiệu ứng
                        cartItem.style.transition = 'opacity 0.3s ease-out';
                        cartItem.style.opacity = '0';

                        setTimeout(() => {
                            cartItem.remove();
                            updateOrderSummary(); // Cập nhật tóm tắt đơn hàng
                            updateCartState(); // Kiểm tra giỏ hàng trống

                            // TODO: Gửi yêu cầu xóa đến máy chủ
                            // fetch('@Url.Action("RemoveFromCart", "Cart")/' + bookId, { method: 'POST' });
                        }, 300);
                    }
                });
            });

            // Xử lý thay đổi số lượng
            const quantityInputs = document.querySelectorAll('.quantity');
            quantityInputs.forEach(input => {
                input.addEventListener('change', function() {
                    const cartItem = this.closest('.cart-item');
                    const bookId = cartItem.getAttribute('data-book-id');
                    const quantity = this.value;

                    console.log('Cập nhật số lượng sản phẩm ' + bookId + ' thành ' + quantity);
                    updateOrderSummary(); // Cập nhật tóm tắt đơn hàng
                    // TODO: Gửi yêu cầu cập nhật số lượng đến máy chủ
                    // fetch('@Url.Action("UpdateQuantity", "Cart")/' + bookId, { method: 'POST', body: JSON.stringify({ quantity: quantity }) });
                });
            });
        });
    </script>
}


