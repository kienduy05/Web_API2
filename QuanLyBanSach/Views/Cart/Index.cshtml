@model List<QuanLyBanSach.Models.CartItemDetail>
@{
    Layout = "~/Views/Shared/_LayoutBook.cshtml";
}

<!-- 🛒 CART SECTION -->
<section class="container py-5">
    <h4 class="section-title">Giỏ hàng của tôi</h4>
    <div class="row g-4">
        <div class="col-lg-8">
            <!-- Thông báo giỏ hàng trống -->
            <div class="empty-cart-message" id="emptyCartMessage" style="display: @(Model.Count == 0 ? "block" : "none")">
                <div class="card border-0 shadow-sm p-5 text-center">
                    <i class="bi bi-cart-x" style="font-size: 3rem; color: #dc3545;"></i>
                    <h5 class="mt-3 fw-bold">Giỏ hàng của bạn trống</h5>
                    <p class="text-muted">Hãy tiếp tục mua sắm để thêm sản phẩm vào giỏ hàng.</p>
                    <a href="@Url.Action("Index", "Book")" class="btn btn-theme mt-3">Tiếp tục mua sắm</a>
                </div>
            </div>

            <!-- Sản phẩm giỏ hàng -->
            <div class="cart-items-container" id="cartItemsContainer">
                @foreach (var item in Model)
                {
                    <div class="card border-0 shadow-sm mb-3 p-3 d-flex flex-row align-items-center cart-item" data-book-id="@item.BookId">
                        @if (!string.IsNullOrEmpty(item.BookImage))
                        {
                            <img src="@Url.Content($"~/images/books/{item.BookImage}")" class="rounded me-3"
                                 width="80" alt="">
                        }
                        else
                        {
                            <div class="rounded me-3 bg-light d-flex align-items-center justify-content-center"
                                 style="width: 80px; height: 80px;">
                                <i class="bi bi-image text-muted"></i>
                            </div>
                        }
                        <div class="flex-grow-1">
                            <h6 class="fw-bold mb-1">@item.BookName</h6>
                            <p class="text-muted small mb-1">@item.PublisherName</p>
                            <p class="fw-semibold text-danger mb-0">@item.BookPrice.ToString("N0") ₫</p>
                        </div>
                        <div>
                            <input type="number" class="form-control form-control-sm mb-2 quantity" value="@item.Quantity" min="1"
                                   style="width: 70px;">
                            <button type="button" class="btn btn-sm btn-outline-danger delete-btn">Xóa</button>
                        </div>
                    </div>
                }
            </div>
        </div>

        <div class="col-lg-4">
            <div class="card border-0 shadow-sm p-3">
                <h6 class="fw-bold mb-3">Tóm tắt đơn hàng</h6>
                <div class="d-flex justify-content-between mb-2">
                    <span>Tạm tính</span><span id="subtotal">₹0</span>
                </div>
                <div class="d-flex justify-content-between mb-2">
                    <span>Vận chuyển</span><span id="shipping">50,000 ₫</span>
                </div>
                <hr>
                <div class="d-flex justify-content-between fw-bold mb-3">
                    <span>Tổng</span><span id="total">₹50</span>
                </div>
                <button class="btn btn-theme w-100" id="checkoutBtn" 
                        onclick="location.href='@Url.Action("Index", "Checkout")'">
                    <i class="bi bi-credit-card me-2"></i>
                    Tiến hành thanh toán
                </button>
            </div>
        </div>
    </div>
</section>

@section Scripts {
    <script src="~/js/services/cartService.js"></script>
    <script>
        const formatCurrency = (value) => value.toLocaleString('vi-VN') + ' ₫';

        const parsePrice = (text) => parseFloat(text.replace(/\s/g, '').replace('₫', '').replace(/,/g, ''));

        function updateSummary() {
            const cartItems = document.querySelectorAll('.cart-item');
            const subtotal = Array.from(cartItems).reduce((sum, item) => {
                const price = parsePrice(item.querySelector('.fw-semibold.text-danger')?.textContent || '0');
                const qty = parseInt(item.querySelector('.quantity')?.value || '0');
                return sum + (price * qty);
            }, 0);

            document.getElementById('subtotal').textContent = formatCurrency(subtotal);
            document.getElementById('total').textContent = formatCurrency(subtotal + 50000);

            const isEmpty = cartItems.length === 0;
            document.getElementById('emptyCartMessage').style.display = isEmpty ? 'block' : 'none';
            document.getElementById('checkoutBtn').disabled = isEmpty;
        }

        const removeFromCart = (bookId, cartItem) => {
            console.log(`Removing bookId: ${bookId}`);
            cartService.removeFromCart(bookId)
                .then(data => {
                    console.log('Response:', data);
                    if (data.success) {
                        cartItem.style.opacity = '0';
                        setTimeout(() => { cartItem.remove(); updateSummary(); }, 300);
                    } else alert('❌ ' + data.message);
                })
                .catch(e => alert('Lỗi xóa: ' + e.message));
        };

        const updateQuantity = (bookId, quantity) => {
            if (quantity <= 0) {
                alert('Số lượng phải lớn hơn 0');
                location.reload();
                return;
            }
            cartService.updateQuantity(bookId, quantity)
                .then(data => {
                    if (!data.success) { alert('❌ ' + data.message); location.reload(); }
                    else updateSummary();
                })
                .catch(() => alert('Lỗi cập nhật số lượng'));
        };

        document.addEventListener('DOMContentLoaded', () => {
            updateSummary();

            document.querySelectorAll('.delete-btn').forEach(btn => {
                btn.addEventListener('click', (e) => {
                    const cartItem = btn.closest('.cart-item');
                    const bookId = parseInt(cartItem?.getAttribute('data-book-id'));
                    console.log(`Delete clicked - bookId: ${bookId}, isNaN: ${isNaN(bookId)}`);
                    if (!isNaN(bookId) && confirm('Bạn có chắc chắn muốn xóa sản phẩm này?')) 
                        removeFromCart(bookId, cartItem);
                });
            });

            document.querySelectorAll('.quantity').forEach(input => {
                input.addEventListener('change', function() {
                    const cartItem = this.closest('.cart-item');
                    const bookId = parseInt(cartItem?.getAttribute('data-book-id'));
                    const quantity = parseInt(this.value);
                    console.log(`Quantity changed - bookId: ${bookId}, quantity: ${quantity}, isNaN: ${isNaN(bookId)}`);
                    if (!isNaN(bookId) && !isNaN(quantity)) updateQuantity(bookId, quantity);
                });
            });
        });
    </script>
}


