@model QuanLyBanSach.Models.Book
@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers

@{
    ViewData["Title"] = "Chi tiết sách";
    Layout = "~/Views/Shared/_LayoutBook.cshtml";
}

<section class="book-details py-5 bg-light">
    <div class="container">
        <div class="row">

            <!-- IMAGE -->
            <div class="col-lg-5 mb-4">
                <div class="card border-0 shadow-sm">

                    @if (!string.IsNullOrEmpty(Model.BookImage))
                    {
                        <img src="@Url.Content($"~/images/books/{Model.BookImage}")"
                             class="img-fluid rounded" />
                    }
                    else
                    {
                        <div style="height:300px;background:#eee;
                            display:flex;align-items:center;justify-content:center;">
                            <i class="bi bi-image fs-1 text-muted"></i>
                        </div>
                    }

                </div>
            </div>

            <!-- INFO -->
            <!-- INFO -->
            <div class="col-lg-7">

                <div class="row">
        
                    <!-- LEFT: INFO TEXT -->
                    <div class="col-md-7">

                        <!-- NAME -->
                        <h2 class="fw-bold text-danger mb-2">
                            @Model.BookName
                        </h2>

                        <!-- AUTHOR -->
                        <p class="text-muted mb-1">
                            Tác giả: <strong>@Model.AuthorName</strong>
                        </p>

                        <!-- CATEGORY -->
                        <p class="text-muted mb-1">
                            Thể loại: <strong>@Model.BookCategoryName</strong>
                        </p>

                        <!-- PUBLISHER -->
                        <p class="text-muted mb-3">
                            Nhà xuất bản: <strong>@Model.PublisherName</strong>
                        </p>

                        <!-- PRICE -->
                        <h3 class="text-danger mb-3">
                            @Model.BookPrice.ToString("N0") ₫
                        </h3>

                    </div>

                    <!-- RIGHT: BOX NHỎ -->
                    <div class="col-md-5">
                        <div class="info-box p-3">

                            <div class="d-flex align-items-center mb-2">
                                <i class="bi bi-truck fs-5 me-2"></i>
                                <span>Giao hàng toàn quốc</span>
                            </div>

                            <div class="d-flex align-items-center mb-2">
                                <i class="bi bi-star fs-5 me-2"></i>
                                <span>Sản phẩm chính hãng</span>
                            </div>

                            <div class="d-flex align-items-center mb-2">
                                <i class="bi bi-gift fs-5 me-2"></i>
                                <span>Tích điểm đổi quà</span>
                            </div>

                            <div class="d-flex align-items-center">
                                <i class="bi bi-ticket-perforated fs-5 me-2"></i>
                                <span>Nhiều ưu đãi</span>
                            </div>

                        </div>
                    </div>

                </div>

                <!-- DESCRIPTION -->
                <p class="text-muted mb-4 mt-3">
                    @(string.IsNullOrEmpty(Model.BookDescription)
                        ? "Chưa có mô tả cho sách này."
                        : Model.BookDescription)
                </p>

                <!-- QUANTITY -->
                <p class="mb-3">
                    <strong>Số lượng còn:</strong> @Model.BookQuantity
                </p>

                <!-- STATUS -->
                <p class="mb-4">
                    <strong>Trạng thái:</strong>
                    @if (Model.BookStatus == 1)
                    {
                        <span class="badge bg-success">Đang bán</span>
                    }
                    else
                    {
                        <span class="badge bg-danger">Ngừng bán</span>
                    }
                </p>

                <!-- BUTTON -->
                <div class="d-flex gap-3">
                    <button type="button" class="btn btn-buy text-white px-4 d-flex align-items-center"
                        data-bs-toggle="modal" data-bs-target="#addToCartModal"
                        @(Model.BookStatus == 0 ? "disabled" : "")>
                        <i class="fas fa-shopping-cart me-2"></i>
                        Thêm vào giỏ hàng
                    </button>
                </div>

            </div>
        </div>

        <!-- RELATED (demo tạm) -->
        <div class="mt-5">
            <h4 class="fw-bold mb-4 text-orange">Sách liên quan</h4>
            <div class="row gy-4">

                @foreach (var item in (List<QuanLyBanSach.Models.Book>)ViewBag.RelatedBooks)
                {
                    <div class="col-md-3">
                        <a asp-controller="Book"
                               asp-action="Detail"
                               asp-route-id="@item.BookID"
                               style="text-decoration:none">

                            <div class="card border-0 shadow-sm h-100">

                                @if (!string.IsNullOrEmpty(item.BookImage))
                                {
                                    <img src="@Url.Content($"~/images/books/{item.BookImage}")"
                                         class="card-img-top"
                                         style="height:220px;object-fit:contain;background:#f8f8f8;" />
                                }

                                <div class="card-body">
                                    <h6 class="fw-bold mb-1">@item.BookName</h6>
                                    <p class="text-muted small mb-1">@item.AuthorName</p>
                                    <p class="fw-semibold text-orange mb-0">
                                        @item.BookPrice.ToString("N0") ₫
                                    </p>
                                </div>

                            </div>
                        </a>
                    </div>
                    
                }

            </div>
        </div>

        <a asp-controller="Book" asp-action="Index"
               class="btn btn-danger back-to-list">
            ← Quay lại
        </a>

        <style>
                    .back-to-list {
                        position: fixed;
                        bottom: 20px;
                        right: 20px;
                        z-index: 999;
                        border-radius: 20px ;
                        padding: 10px 18px;
                        box-shadow: 0 4px 10px rgba(0,0,0,0.2);
                        background-color: #ED553B;
                    }                
        </style>
            <div class="mt-5 p-4 bg-white shadow-sm rounded">
                <h5 class="fw-bold mb-4">Đánh giá sản phẩm</h5>

                <div class="row">
                    <!-- Tổng rating -->
                    <div class="col-md-3 text-center border-end">
                        <h1 class="fw-bold">5<span class="fs-5">/5</span></h1>
                        <div class="text-warning fs-4">★★★★★</div>
                        <p class="text-muted">(18 đánh giá)</p>
                    </div>

                    <!-- Thanh rating -->
                    <div class="col-md-5">
                        @for (int i = 5; i >= 1; i--)
                        {
                            <div class="d-flex align-items-center mb-2">
                                <span class="me-2">@i sao</span>
                                <div class="progress flex-grow-1 me-2" style="height:6px;">
                                    <div class="progress-bar bg-warning" style="width:@(i == 5 ? "90%" : i == 4 ? "20%" : "0%")"></div>
                                </div>
                                <small>@(i == 5 ? "90%" : i == 4 ? "20%" : "0%")</small>
                            </div>
                        }
                    </div>

                    
                    
                </div>

                <hr />

                <!-- Danh sách comment -->
                <div class="mt-3">
                    <div class="mb-4">
                        <strong>ngoc vinh</strong>
                        <div class="text-warning">★★★★☆</div>
                        <small class="text-muted">21/03/2026</small>
                        <p class="mt-2">
                            Sách rất hay, nội dung sâu sắc và lôi cuốn. Đọc rất cuốn, đáng mua!
                        </p>
                    </div>

                    <div class="mb-4">
                        <strong>minh nhật</strong>
                        <div class="text-warning">★★★★★</div>
                        <small class="text-muted">20/03/2026</small>
                        <p class="mt-2">
                            Nội dung rất chất lượng, trình bày đẹp, giao hàng nhanh.
                        </p>
                    </div>
                    <div class="mb-4">
                        <strong>Nam</strong>
                        <div class="text-warning">★★★★★</div>
                        <small class="text-muted">16/03/2024</small>
                        <p class="mt-2">
                            
                        Sách rất hay, nội dung sâu sắc và lôi cuốn. Tôi đã dành cả đêm để đọc hết cuốn sách này vì cốt truyện quá tuyệt vời. Cảm ơn Fahasa đã giao hàng nhanh và đóng gói rất cẩn thận, không bị móp góc. Sách rất hay, nội dung sâu sắc và lôi cuốn. Tôi đã dành cả đêm để đọc hết cuốn sách này vì cốt truyện quá tuyệt vời. Cảm ơn Fahasa đã giao hàng nhanh và đóng gói rất cẩn thận, không bị móp góc.
                        </p>
                    </div>
                </div>
            </div>
    </div>
</section>
<style>
    .info-box {
        background: linear-gradient(135deg, #eef3ff, #dbe6ff);
        border: 2px dashed #4a7dff;
        border-radius: 12px;
        font-size: 14px;
    }

        .info-box i {
            color: #333;
        }
</style>

<!-- Modal: Thêm vào giỏ hàng -->
<div class="modal fade" id="addToCartModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Thêm vào giỏ hàng</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <p class="mb-3"><strong>Sản phẩm:</strong> @Model.BookName</p>
                <p class="mb-3"><strong>Giá:</strong> @Model.BookPrice.ToString("N0") ₫</p>
                <p class="mb-3"><strong>Số lượng còn:</strong> @Model.BookQuantity</p>

                <div class="mb-3">
                    <label for="quantityInput" class="form-label"><strong>Số lượng:</strong></label>
                    <input type="number" class="form-control" id="quantityInput" 
                           value="1" min="1" max="@Model.BookQuantity">
                    <small class="text-danger" id="quantityError" style="display:none;"></small>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Hủy</button>
                <button type="button" class="btn btn-danger" id="confirmAddToCart">Thêm vào giỏ hàng</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        const bookId = @Model.BookID;
        const maxQuantity = @Model.BookQuantity;

        // Prevent input from exceeding max quantity
        document.getElementById('quantityInput').addEventListener('input', function() {
            const quantity = parseInt(this.value) || 0;
            const errorDiv = document.getElementById('quantityError');

            if (quantity > maxQuantity) {
                this.value = maxQuantity;
                errorDiv.textContent = `Số lượng không thể vượt quá ${maxQuantity}`;
                errorDiv.style.display = 'block';
            } else if (quantity < 1 && this.value !== '') {
                errorDiv.textContent = 'Vui lòng nhập số lượng >= 1';
                errorDiv.style.display = 'block';
            } else {
                errorDiv.style.display = 'none';
            }
        });

        // Handle add to cart
        document.getElementById('confirmAddToCart').addEventListener('click', function() {
            const quantityInput = document.getElementById('quantityInput');
            let quantity = parseInt(quantityInput.value) || 0;
            const errorDiv = document.getElementById('quantityError');

            // Final validation before sending
            if (quantity < 1) {
                errorDiv.textContent = 'Vui lòng nhập số lượng >= 1';
                errorDiv.style.display = 'block';
                quantityInput.focus();
                return;
            }

            if (quantity > maxQuantity) {
                quantity = maxQuantity;
                quantityInput.value = maxQuantity;
                errorDiv.textContent = `Số lượng không thể vượt quá ${maxQuantity}`;
                errorDiv.style.display = 'block';
                return;
            }

            // Send to server
            fetch('@Url.Action("AddToCart", "Cart")', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                },
                body: JSON.stringify({
                    bookId: bookId,
                    quantity: quantity
                })
            })
            .then(response => response.json())
            .then(data => {
                if (data.success) {
                    alert('Thêm vào giỏ hàng thành công!');
                    // Close modal
                    bootstrap.Modal.getInstance(document.getElementById('addToCartModal')).hide();
                    // Reset form
                    quantityInput.value = '1';
                    errorDiv.style.display = 'none';
                    // Optionally redirect to cart
                    // location.href = '@Url.Action("Index", "Cart")';
                } else {
                    alert('Lỗi: ' + data.message);
                }
            })
            .catch(error => {
                console.error('Error:', error);
                alert('Có lỗi xảy ra. Vui lòng thử lại!');
            });
        });

        // Reset modal when closed
        document.getElementById('addToCartModal').addEventListener('hidden.bs.modal', function() {
            document.getElementById('quantityInput').value = '1';
            document.getElementById('quantityError').style.display = 'none';
        });
    </script>
}