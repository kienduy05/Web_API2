@model List<QuanLyBanSach.Models.Book>
@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers

@{
    ViewData["Title"] = "Books";
    Layout = "~/Views/Shared/_LayoutBook.cshtml";
}

<script>
    function updatePrice(value) {
        document.getElementById("priceValue").innerText =
            Number(value).toLocaleString() + " ₫";
        document.getElementById("maxPrice").value = value;
    }

    window.onload = function () {
        let value = document.getElementById("priceRange").value;
        updatePrice(value);
    }
</script>

<section class="books-section py-5 bg-light">
    <div class="container">
        <div class="row">

            <!-- FILTER -->
            <div class="col-lg-3 mb-4">
                <div class="card border-0 shadow-sm p-3">
                    <h5 class="fw-bold mb-3 text-orange">Bộ lọc</h5>

                    <form method="get" asp-controller="Book" asp-action="Index">

                        <!-- CATEGORY -->
                        <div class="mb-4">
                            <h6 class="fw-semibold">Thể loại</h6>

                            <div class="form-check">
                                <input class="form-check-input" type="radio"
                                       name="categoryId" value=""
                                @(ViewBag.CategoryId == null ? "checked" : "") />
                                <label>Tất cả</label>
                            </div>

                            @foreach (var cat in ViewBag.Categories)
                            {
                                <div class="form-check">
                                    <input class="form-check-input" type="radio"
                                           name="categoryId" value="@cat.BookCategoryID"
                                    @(ViewBag.CategoryId == cat.BookCategoryID ? "checked" : "") />
                                    <label>@cat.BookCategoryName</label>
                                </div>
                            }
                        </div>

                        <!-- AUTHOR -->
                        <div class="mb-4">
                            <h6 class="fw-semibold">Tác giả</h6>
                            <select name="authorId" class="form-select">
                                <option value="">Tất cả</option>
                                @foreach (var a in ViewBag.Authors)
                                {
                                    <option value="@a.AuthorID"
                                            selected="@(ViewBag.AuthorId == a.AuthorID)">
                                        @a.AuthorName
                                    </option>
                                }
                            </select>
                        </div>

                        <!-- PRICE -->
                        <div class="mb-4">
                            <h6 class="fw-semibold">Giá tối đa</h6>

                            <input type="range"
                                   class="form-range"
                                   min="10000" max="2000000" step="50000"
                                   id="priceRange"
                                   value="@(ViewBag.MaxPrice ?? 2000000)"
                                   oninput="updatePrice(this.value)" />

                            <div class="d-flex justify-content-between">
                                <small>10,000 ₫</small>
                                <small id="priceValue"></small>
                            </div>

                            <input type="hidden" name="maxPrice" id="maxPrice"
                                   value="@(ViewBag.MaxPrice ?? 2000000)" />
                        </div>

                        <button class="btn text-white w-100"
                                style="background:#ED553B;">
                            Áp dụng
                        </button>

                        <a asp-controller="Book" asp-action="Index"
                               class="btn btn-outline-secondary w-100 mt-2">
                            Làm mới
                        </a>
                    </form>
                </div>
            </div>

            <!-- BOOK LIST -->
            <div class="col-lg-9">

                <!-- HEADER -->
                <div class="d-flex justify-content-between mb-4">
                    <h4 class="fw-bold">
                        Danh sách sách
                        <small class="text-muted">
                            (@ViewBag.TotalItems)
                        </small>
                    </h4>

                    <form method="get" asp-action="Index">
                        <input type="hidden" name="categoryId" value="@ViewBag.CategoryId" />
                        <input type="hidden" name="authorId" value="@ViewBag.AuthorId" />
                        <input type="hidden" name="maxPrice" value="@ViewBag.MaxPrice" />

                        <select name="sort" class="form-select"
                                onchange="this.form.submit()">

                            <option value="">Sắp xếp</option>

                            <option value="price_asc"
                                    selected="@(ViewBag.Sort == "price_asc")">
                                Giá tăng
                            </option>

                            <option value="price_desc"
                                    selected="@(ViewBag.Sort == "price_desc")">
                                Giá giảm
                            </option>

                            <option value="newest"
                                    selected="@(ViewBag.Sort == "newest")">
                                Mới nhất
                            </option>
                        </select>
                    </form>
                </div>

                <!-- EMPTY -->
                @if (!Model.Any())
                {
                    <div class="text-center py-5">
                        <p>Không có sách</p>
                    </div>
                }
                else
                {
                    <div class="row g-4">
                        @foreach (var book in Model)
                        {
                            <div class="col-md-4">

                                <a asp-action="Detail"
                                       asp-route-id="@book.BookID"
                                       style="text-decoration:none">

                                    <div class="card shadow-sm h-100">

                                        @if (!string.IsNullOrEmpty(book.BookImage))
                                        {
                                            <img src="@Url.Content($"~/images/books/{book.BookImage}")"
                                                 style="height:220px;object-fit:contain;background:#f8f8f8;" />
                                        }

                                        <div class="card-body">
                                            <h6>@book.BookName</h6>
                                            <p class="text-muted">@book.AuthorName</p>
                                            <p class="fw-bold text-danger">
                                                @book.BookPrice.ToString("N0") ₫
                                            </p>
                                        </div>
                                    </div>

                                </a>
                            </div>
                        }
                    </div>

                    <!-- PAGINATION -->
                    @if (ViewBag.TotalPages > 1)
                    {
                        <nav class="mt-4">
                            <ul class="pagination justify-content-center">

                                @for (int i = 1; i <= ViewBag.TotalPages; i++)
                                {
                                    <li class="page-item @(i == ViewBag.CurrentPage ? "active" : "")">

                                        <a class="page-link"
                                               asp-action="Index"
                                               asp-route-page="@i"
                                               asp-route-categoryId="@ViewBag.CategoryId"
                                               asp-route-authorId="@ViewBag.AuthorId"
                                               asp-route-maxPrice="@ViewBag.MaxPrice"
                                               asp-route-sort="@ViewBag.Sort">
                                            @i
                                        </a>

                                    </li>
                                }

                            </ul>
                        </nav>
                    }
                }

            </div>
        </div>
    </div>
</section>